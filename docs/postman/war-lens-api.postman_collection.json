        {
          "name": "Create Conflict",
          "request": {
            "description": "Create a new conflict entry (admin only).",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"conflictName\": \"Gulf War\",\n  \"conflictType\": \"Interstate War\",\n  \"region\": \"Middle East\",\n  \"startYear\": 1990,\n  \"endYear\": 1991,\n  \"status\": \"Resolved\",\n  \"primaryCountry\": \"Iraq\",\n  \"gdpChange\": -15.5,\n  \"inflationRate\": 25.0,\n  \"warCostUsd\": 61000000000,\n  \"reconstructionCostUsd\": 80000000000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/conflicts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "conflicts"
              ]
            }
          }
        },
        {
          "name": "Replace Conflict",
          "request": {
            "description": "Replace all fields of an existing conflict (admin only).",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"conflictName\": \"Gulf War (Replaced)\",\n  \"conflictType\": \"Interstate War\",\n  \"region\": \"Middle East\",\n  \"startYear\": 1990,\n  \"endYear\": 1991,\n  \"status\": \"Resolved\",\n  \"primaryCountry\": \"Iraq\",\n  \"gdpChange\": -16.2,\n  \"inflationRate\": 26.5,\n  \"warCostUsd\": 62000000000,\n  \"reconstructionCostUsd\": 85000000000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/conflicts/{{conflictId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "conflicts",
                "{{conflictId}}"
              ]
            }
          }
        },
        {
          "name": "Update Conflict",
          "request": {
            "description": "Update fields of an existing conflict (admin only).",
